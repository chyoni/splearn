<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings xmlns="http://www.hibernate.org/xsd/orm/mapping"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:schemaLocation="http://www.hibernate.org/xsd/orm/mapping
                                     https://hibernate.org/xsd/orm/mapping/mapping-3.1.0.xsd">
    <access>FIELD</access>

    <mapped-superclass class="cwchoiit.splearn.member.domain.BaseEntity">
        <attributes>
            <id name="id">
                <column name="id"/>
                <generated-value strategy="IDENTITY"/>
            </id>
        </attributes>
    </mapped-superclass>

    <entity class="cwchoiit.splearn.member.domain.Member">
        <table name="member">
            <unique-constraint name="uk_member_email">
                <column-name>email</column-name>
            </unique-constraint>
            <unique-constraint name="uk_member_member_detail_id">
                <column-name>member_detail_id</column-name>
            </unique-constraint>
        </table>
        <attributes>
            <basic name="nickname">
                <column name="nickname" nullable="false" length="100"/>
            </basic>
            <basic name="passwordHash">
                <column name="password_hash" nullable="false" length="200"/>
            </basic>
            <basic name="status">
                <column name="status" nullable="false" length="50"/>
                <enumerated>STRING</enumerated>
            </basic>
            <one-to-one name="detail" fetch="LAZY">
                <join-column name="member_detail_id"/>
                <cascade>
                    <cascade-all/>
                </cascade>
            </one-to-one>
            <embedded name="email">
            </embedded>
        </attributes>
    </entity>

    <entity class="cwchoiit.splearn.member.domain.MemberDetail">
        <table name="member_detail">
            <unique-constraint name="uk_member_detail_profile">
                <column-name>profile</column-name>
            </unique-constraint>
        </table>
        <attributes>
            <basic name="introduction">
                <column name="introduction" nullable="true" column-definition="TEXT"/>
            </basic>
            <basic name="registeredAt">
                <column name="registered_at" nullable="false"/>
            </basic>
            <basic name="activatedAt">
                <column name="activated_at" nullable="true"/>
            </basic>
            <basic name="deactivatedAt">
                <column name="deactivated_at" nullable="true"/>
            </basic>
            <embedded name="profile">
            </embedded>
        </attributes>
    </entity>

    <embeddable class="cwchoiit.splearn.member.domain.vo.Email">
        <attributes>
            <basic name="email">
                <column name="email" nullable="false" length="150"/>
            </basic>
        </attributes>
    </embeddable>

    <embeddable class="cwchoiit.splearn.member.domain.vo.Profile">
        <attributes>
            <basic name="profile">
                <column name="profile" nullable="true" length="15"/>
            </basic>
        </attributes>
    </embeddable>
</entity-mappings>